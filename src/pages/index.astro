---
import Base from '../layouts/Base.astro';
import { logo } from '../lib/logos';

import { CHROME_URL as chromeUrl } from '../consts';
// Gumroad checkout links (one per product/period), public permalinks.
const gumroad = {
  hobby: {
    monthly: 'https://karmatracker.gumroad.com/l/hobbyist-monthly',
    yearly: 'https://karmatracker.gumroad.com/l/hobbyist-yearly',
  },
  expert: {
    monthly: 'https://karmatracker.gumroad.com/l/expert-monthly',
    yearly: 'https://karmatracker.gumroad.com/l/expert-yearly',
  },
};

const firstClass = [
  { name: 'Claude', what: '5-hour & weekly windows, per-model (Fable)', color: '#D97757' },
  { name: 'ChatGPT', what: 'Per-feature caps: research, image, uploads', color: '#10A37F' },
  { name: 'Codex', what: '5-hour & weekly usage windows', color: '#0E8C6E' },
  { name: 'Cursor', what: 'Monthly fast-request quota', color: '#0B0B0C' },
  { name: 'Grok', what: 'Per-window request quota', color: '#111827' },
  { name: 'Perplexity', what: 'Pro-search allowance', color: '#20808D' },
];
const features = [
  { t: 'Live limits', d: 'Real remaining tokens, messages and reset times read straight from your own sessions - no API keys required.', i: '📊' },
  { t: 'Smart alerts', d: 'Get warned before you hit the wall, and a nudge to rest during peak hours when limits burn faster.', i: '🔔' },
  { t: 'Peak hours', d: 'Know when shared capacity is tight so you can plan heavy work around the crunch.', i: '🌙' },
  { t: 'Usage history', d: 'See your runway over time with per-provider charts. Spot trends and plan your week.', i: '📈' },
  { t: 'One dashboard', d: 'Claude, ChatGPT, Codex, Grok and Perplexity - all in a single toolbar popup.', i: '🧭' },
  { t: 'You keep the keys', d: 'Everything runs locally in your browser. Your sessions never leave your machine.', i: '🔒' },
];
const faqs = [
  ['Do I need to paste API keys?', 'No. Limit tracking reads your existing logged-in sessions in the browser. API keys are only optional, for tools that have no web session (like Claude Code).'],
  ['Which tools are fully tracked?', 'Claude, ChatGPT, Codex, Cursor, Grok and Perplexity get live limit numbers today. More are on the way.'],
  ['Is my data private?', 'Yes - the extension runs entirely in your browser. Usage is stored locally; nothing is sent to us.'],
  ['How does billing work?', 'Payments are handled securely by Gumroad. You can switch monthly/yearly or cancel anytime from the billing portal.'],
];
---
<Base>
  <header class="wrap" style="padding:72px 24px 24px; text-align:center">
    <div style="display:inline-flex; gap:8px; align-items:center; font-size:13px; font-weight:600; color:var(--brand-ink); background:#eef2ff; border:1px solid #e0e7ff; padding:6px 12px; border-radius:999px">
      <span>●</span> Works in Chrome - free to start
    </div>
    <h1 style="font-size:56px; margin:22px auto 0; max-width:760px">
      See your AI limits <span style="background:linear-gradient(120deg,var(--brand),var(--brand-2));-webkit-background-clip:text;background-clip:text;color:transparent">before they stop you.</span>
    </h1>
    <p class="muted" style="font-size:19px; max-width:620px; margin:20px auto 0">
      Live usage, reset times and smart alerts for Claude, ChatGPT, Codex, Cursor, Grok and Perplexity - in one clean dashboard. No API keys needed.
    </p>
    <div style="display:flex; gap:12px; justify-content:center; margin-top:30px; flex-wrap:wrap">
      <a class="btn" href={chromeUrl}>Add to Chrome - free</a>
      <a class="btn ghost" href="#features">See how it works</a>
    </div>

    <!-- Self-playing live dashboard -->
    <div id="demo" class="card" style="max-width:440px; margin:48px auto 0; padding:18px; text-align:left; position:relative; overflow:hidden">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px">
        <b>Your AI stack</b><span class="muted" style="font-size:12px">live</span>
      </div>
      <div style="display:grid; gap:11px; margin-top:10px">
        <!-- Claude (bar) -->
        <div>
          <div class="d-row"><Fragment set:html={logo('Claude')} /><span>Claude · 5-hour</span><span id="d-claude-v" class="d-val">53% left · resets 4h</span></div>
          <div class="d-track"><div id="d-claude-b" style="width:47%; background:linear-gradient(90deg,#f59e0b,#f97316)"></div></div>
        </div>
        <!-- Codex (bar) -->
        <div>
          <div class="d-row"><Fragment set:html={logo('Codex')} /><span>Codex · 5-hour</span><span id="d-codex-v" class="d-val">97% left · resets 4h</span></div>
          <div class="d-track"><div id="d-codex-b" style="width:3%; background:#16a34a"></div></div>
        </div>
        <!-- Cursor (bar) -->
        <div>
          <div class="d-row"><Fragment set:html={logo('Cursor')} /><span>Cursor · monthly</span><span id="d-cursor-v" class="d-val">39% left</span></div>
          <div class="d-track"><div id="d-cursor-b" style="width:61%; background:#6366f1"></div></div>
        </div>
        <!-- ChatGPT (count) -->
        <div class="d-row"><Fragment set:html={logo('ChatGPT')} /><span>ChatGPT · Image gen</span><span id="d-gpt-v" class="d-val">120 left</span></div>
        <!-- Grok (count) -->
        <div class="d-row"><Fragment set:html={logo('Grok')} /><span>Grok</span><span id="d-grok-v" class="d-val">2 / 2 left</span></div>
        <!-- Perplexity (count) -->
        <div class="d-row"><Fragment set:html={logo('Perplexity')} /><span>Perplexity · Pro</span><span id="d-plx-v" class="d-val">5 left</span></div>
      </div>
      <div id="d-toast" style="margin-top:12px; padding:10px 12px; border-radius:10px; background:#fff7ed; border:1px solid #fed7aa; font-size:13px; color:#9a3412; opacity:0; transform:translateY(6px); transition:opacity .4s ease, transform .4s ease">
        ⚠️ <span id="d-toast-t">Claude at ~53% - plan around your 4h reset.</span>
      </div>
    </div>
  </header>

  <section id="features" class="wrap" style="padding:80px 24px 0">
    <h2 class="reveal" style="font-size:34px; text-align:center">One dashboard to rule your whole stack</h2>
    <p class="muted reveal" style="text-align:center; max-width:600px; margin:14px auto 0; font-size:17px">Everything you need to never hit a limit by surprise.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px; margin-top:36px">
      {features.map((f) => (
        <div class="card reveal" style="padding:22px">
          <div style="font-size:26px">{f.i}</div>
          <h3 style="font-size:18px; margin-top:12px">{f.t}</h3>
          <p class="muted" style="margin-top:8px; font-size:15px">{f.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="wrap" style="padding:80px 24px 0">
    <h2 class="reveal" style="font-size:30px; text-align:center">First-class providers</h2>
    <p class="muted reveal" style="text-align:center; max-width:620px; margin:12px auto 0; font-size:16px">Full limit tracking: live usage, reset times and alerts before you hit a wall.</p>
    <div class="card reveal" style="margin-top:28px; overflow:hidden; padding:0">
      {firstClass.map((p, i) => (
        <div class="fp-row" style={i>0 ? 'border-top:1px solid var(--border)' : ''}>
          <Fragment set:html={logo(p.name)} />
          <b class="fp-name">{p.name}</b>
          <span class="muted fp-what">{p.what}</span>
        </div>
      ))}
    </div>
    <p class="muted" style="text-align:center; margin-top:16px; font-size:14px">
      …plus more tools via API key. <a href="/integrations" style="color:var(--brand); font-weight:600">See all integrations →</a>
    </p>
  </section>

  <section id="pricing" class="wrap" style="padding:80px 24px 0">
    <h2 class="reveal" style="font-size:34px; text-align:center">Simple, honest pricing</h2>
    <p class="muted reveal" style="text-align:center; margin-top:12px; font-size:17px">Start free. Upgrade when you want the whole stack.</p>

    <div style="display:flex; justify-content:center; margin-top:22px">
      <div id="billing" style="display:inline-flex; background:var(--bg-soft); border:1px solid var(--border); border-radius:999px; padding:4px">
        <button data-bill="monthly" class="bill-btn is-on">Monthly</button>
        <button data-bill="yearly" class="bill-btn">Yearly <span style="color:var(--ok); font-weight:700">−17%</span></button>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:18px; margin-top:32px; align-items:start">
      <div class="card reveal" style="padding:26px">
        <h3 style="font-size:20px">Free</h3>
        <div style="margin:12px 0 4px"><span style="font-size:40px; font-weight:800">$0</span></div>
        <p class="muted" style="font-size:14px">Track 1 source</p>
        <a class="btn ghost" style="width:100%; margin-top:18px" href={chromeUrl}>Add to Chrome</a>
        <ul class="plan">
          <li>Track any 1 AI tool of your choice</li>
          <li>Live limits &amp; reset times</li>
          <li>Peak-hour &amp; reset alerts</li>
        </ul>
      </div>
      <div class="card reveal" style="padding:26px; border-color:var(--brand); box-shadow:0 10px 30px rgba(99,102,241,.15); position:relative">
        <span style="position:absolute; top:-11px; left:26px; background:var(--brand); color:#fff; font-size:12px; font-weight:700; padding:3px 10px; border-radius:999px">Popular</span>
        <h3 style="font-size:20px">Hobbyist</h3>
        <div style="margin:12px 0 4px">
          <span style="font-size:40px; font-weight:800" data-price="hobby">$2</span>
          <span class="muted" data-per="hobby">/mo</span>
        </div>
        <p class="muted" style="font-size:14px" data-note="hobby">Billed monthly</p>
        <button class="btn" style="width:100%; margin-top:18px" data-checkout="hobby">Choose Hobbyist</button>
        <ul class="plan">
          <li><b>Everything in Free</b></li>
          <li>Track all providers</li>
          <li>Usage history &amp; charts</li>
          <li>Telegram alerts</li>
        </ul>
      </div>
      <div class="card reveal" style="padding:26px">
        <h3 style="font-size:20px">Expert</h3>
        <div style="margin:12px 0 4px">
          <span style="font-size:40px; font-weight:800" data-price="expert">$5</span>
          <span class="muted" data-per="expert">/mo</span>
        </div>
        <p class="muted" style="font-size:14px" data-note="expert">Billed monthly</p>
        <button class="btn ghost" style="width:100%; margin-top:18px" data-checkout="expert">Choose Expert</button>
        <ul class="plan">
          <li><b>Everything in Hobbyist</b></li>
          <li>Extended history retention</li>
          <li>Priority new integrations</li>
          <li>Early access features</li>
        </ul>
      </div>
    </div>
    <p class="muted" style="text-align:center; margin-top:16px; font-size:13px">Secure checkout by Gumroad · cancel anytime</p>
  </section>

  <section class="wrap" style="padding:80px 24px 0; max-width:760px">
    <h2 class="reveal" style="font-size:30px; text-align:center">Frequently asked questions</h2>
    <div style="margin-top:26px; display:grid; gap:10px">
      {faqs.map(([q, a]) => (
        <details class="card reveal" style="padding:16px 20px">
          <summary style="cursor:pointer; font-weight:600; list-style:none; display:flex; justify-content:space-between; align-items:center">{q}<span class="muted">+</span></summary>
          <p class="muted" style="margin-top:10px; font-size:15px">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="wrap" style="padding:72px 24px 0">
    <div class="card reveal" style="text-align:center; padding:48px 24px; background:linear-gradient(135deg,#eef2ff,#faf5ff); border-color:#e0e7ff">
      <h2 style="font-size:32px; max-width:520px; margin:0 auto">Take back control of your AI stack</h2>
      <p class="muted" style="margin:14px auto 0; max-width:480px; font-size:17px">Add the extension, connect your tools, and never hit a limit by surprise again.</p>
      <div style="display:flex; gap:12px; justify-content:center; margin-top:24px; flex-wrap:wrap">
        <a class="btn" href={chromeUrl}>Add to Chrome - free</a>
        <a class="btn ghost" href="/integrations">Browse integrations</a>
      </div>
    </div>
  </section>

  <style>
    .bill-btn { border:0; background:transparent; padding:8px 16px; border-radius:999px; font-weight:600; font-size:14px; cursor:pointer; color:var(--muted); }
    .bill-btn.is-on { background:#fff; color:var(--fg); box-shadow:var(--shadow); }
    ul.plan { list-style:none; padding:0; margin:20px 0 0; display:grid; gap:10px; }
    ul.plan li { position:relative; padding-left:24px; font-size:14.5px; }
    ul.plan li::before { content:'✓'; position:absolute; left:0; color:var(--brand); font-weight:700; }
    details[open] summary span { transform:rotate(45deg); }
    summary span { display:inline-block; transition:transform .15s ease; }
    @keyframes karmaFlash { 0%{background:#dcfce7} 100%{background:#eef0f5} }
    .flash { animation: karmaFlash .8s ease; }
    .fp-row { display:flex; align-items:center; gap:14px; padding:16px 20px; flex-wrap:wrap; }
    .fp-name { flex:0 0 auto; }
    .fp-what { font-size:15px; flex:1 1 200px; min-width:0; }
    @media (min-width:520px) { .fp-name { width:130px; flex-basis:auto; } }
    .d-row { display:flex; align-items:center; gap:9px; font-size:14px; min-width:0; }
    .d-val { margin-left:auto; color:var(--muted); font-size:13.5px; white-space:nowrap; }
    .d-track { height:8px; border-radius:5px; background:#eef0f5; overflow:hidden; margin-top:6px; }
    .d-track > div { height:100%; transition:width .9s ease, background .4s ease; }
  </style>

  <!-- Self-playing demo -->
  <script is:inline>
    (function () {
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) return; // keep the static snapshot
      var $ = function (id) { return document.getElementById(id); };
      var claudeUsed = 47, codexUsed = 3, cursorUsed = 61, gpt = 120, grok = 2, plx = 5;
      function barColor(used) { return used >= 90 ? '#DC2626' : used >= 70 ? '#F59E0B' : '#16A34A'; }
      function toast(msg) {
        var t = $('d-toast'); if (!t) return;
        $('d-toast-t').textContent = msg;
        t.style.background = '#fff7ed'; t.style.borderColor = '#fed7aa'; t.style.color = '#9a3412';
        t.style.opacity = '1'; t.style.transform = 'none';
        setTimeout(function () { t.style.opacity = '0'; t.style.transform = 'translateY(6px)'; }, 2600);
      }
      function tick() {
        var cb = $('d-claude-b'); if (!cb) return; // page gone
        claudeUsed = Math.min(96, claudeUsed + 4 + Math.random() * 5);
        codexUsed = Math.min(60, codexUsed + 2 + Math.random() * 3);
        cursorUsed = Math.min(94, cursorUsed + 1 + Math.random() * 3);
        cb.style.width = claudeUsed + '%'; cb.style.background = claudeUsed >= 70 ? barColor(claudeUsed) : 'linear-gradient(90deg,#f59e0b,#f97316)';
        if (claudeUsed >= 90) cb.style.background = '#DC2626';
        $('d-claude-v').textContent = (100 - Math.round(claudeUsed)) + '% left · resets 4h';
        $('d-codex-b').style.width = codexUsed + '%';
        $('d-codex-v').textContent = (100 - Math.round(codexUsed)) + '% left · resets 4h';
        var xb = $('d-cursor-b'); xb.style.width = cursorUsed + '%'; xb.style.background = cursorUsed >= 85 ? barColor(cursorUsed) : '#6366f1';
        $('d-cursor-v').textContent = (100 - Math.round(cursorUsed)) + '% left';
        if (Math.random() < 0.5 && gpt > 0) { gpt -= Math.ceil(Math.random() * 6); $('d-gpt-v').textContent = Math.max(0, gpt) + ' left'; }
        if (Math.random() < 0.3 && plx > 0) { plx -= 1; $('d-plx-v').textContent = plx + ' left'; }
        if (Math.round(claudeUsed) >= 88) toast('Claude at ' + Math.round(claudeUsed) + '% - resets in 4h.');
        if (claudeUsed >= 96) { setTimeout(reset, 1100); }
      }
      function reset() {
        var cb = $('d-claude-b'); if (!cb) return;
        claudeUsed = 4 + Math.random() * 6; codexUsed = 3; cursorUsed = 61; gpt = 120; grok = 2; plx = 5;
        cb.classList.add('flash'); setTimeout(function () { cb.classList.remove('flash'); }, 800);
        cb.style.background = 'linear-gradient(90deg,#f59e0b,#f97316)';
        cb.style.width = claudeUsed + '%';
        $('d-claude-v').textContent = (100 - Math.round(claudeUsed)) + '% left · resets 4h';
        $('d-codex-b').style.width = codexUsed + '%'; $('d-codex-v').textContent = '97% left · resets 4h';
        $('d-cursor-b').style.width = cursorUsed + '%'; $('d-cursor-b').style.background = '#6366f1'; $('d-cursor-v').textContent = '39% left';
        $('d-gpt-v').textContent = gpt + ' left'; $('d-grok-v').textContent = grok + ' / 2 left'; $('d-plx-v').textContent = plx + ' left';
        var t = $('d-toast'); t.style.background = '#f0fdf4'; t.style.borderColor = '#bbf7d0'; t.style.color = '#15803d';
        $('d-toast-t').textContent = 'Limits reset - you’re good to go. ✅';
        t.style.opacity = '1'; t.style.transform = 'none';
        setTimeout(function () { t.style.opacity = '0'; t.style.transform = 'translateY(6px)'; }, 2400);
      }
      // Only animate while the demo is on screen.
      var running = false, timer = null;
      function start() { if (running) return; running = true; timer = setInterval(tick, 1400); }
      function stop() { running = false; if (timer) clearInterval(timer); }
      var demo = $('demo');
      if ('IntersectionObserver' in window && demo) {
        new IntersectionObserver(function (e) { e[0].isIntersecting ? start() : stop(); }, { threshold: 0.3 }).observe(demo);
      } else { start(); }
    })();
  </script>

  <!-- Gumroad checkout (static hosted links) -->
  <script is:inline define:vars={{ gumroad }}>
    (function () {
      var billing = 'monthly';
      var PRICES = {
        monthly: { hobby: ['$2', '/mo', 'Billed monthly'], expert: ['$5', '/mo', 'Billed monthly'] },
        yearly:  { hobby: ['$20', '/yr', 'Billed yearly · save 17%'], expert: ['$50', '/yr', 'Billed yearly · save 17%'] },
      };
      function apply(mode) {
        billing = mode;
        ['hobby', 'expert'].forEach(function (k) {
          var p = PRICES[mode][k];
          var price = document.querySelector('[data-price="' + k + '"]');
          var per = document.querySelector('[data-per="' + k + '"]');
          var note = document.querySelector('[data-note="' + k + '"]');
          if (price) price.textContent = p[0];
          if (per) per.textContent = p[1];
          if (note) note.textContent = p[2];
        });
        document.querySelectorAll('.bill-btn').forEach(function (b) {
          b.classList.toggle('is-on', b.getAttribute('data-bill') === mode);
        });
      }
      document.querySelectorAll('.bill-btn').forEach(function (b) {
        b.addEventListener('click', function () { apply(b.getAttribute('data-bill')); });
      });
      document.querySelectorAll('[data-checkout]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var plan = btn.getAttribute('data-checkout');
          var url = gumroad[plan] && gumroad[plan][billing];
          if (!url) { alert('Checkout is not configured yet. Set your Gumroad checkout links.'); return; }
          window.location.href = url;
        });
      });
    })();
  </script>
</Base>
