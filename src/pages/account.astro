---
import Base from '../layouts/Base.astro';
// Gumroad manage link (customers manage memberships from their Gumroad library).
const portal = import.meta.env.PUBLIC_GUMROAD_PORTAL_URL ?? 'https://gumroad.com/library';
const hasPortal = portal && portal !== '#';
---
<Base title="Manage your plan - AI Karma Tracker">
  <main class="wrap" style="max-width:520px; padding-top:64px; padding-bottom:40px">
    <div class="panel">
      <h2 style="margin:0">Manage your plan</h2>
      <p class="muted" style="margin-top:8px">Your subscription is handled securely by Gumroad. Change plan, update payment or cancel anytime.</p>

      {hasPortal ? (
        <a class="btn" style="margin-top:18px" href={portal} target="_blank" rel="noopener">Open billing portal →</a>
      ) : (
        <div class="alert ok" style="margin-top:18px; background:#f6f7fb; border-color:var(--border); color:var(--fg)">
          To manage or cancel your subscription, use the <b>“Manage membership”</b> link in your Gumroad receipt email.
        </div>
      )}

      <hr style="border:0;border-top:1px solid var(--border);margin:24px 0" />

      <h3 style="margin:0 0 6px;font-size:16px">Activate Pro in the extension</h3>
      <ol class="muted" style="margin:0;padding-left:20px;font-size:14.5px;line-height:1.9">
        <li>Open the extension → <b>Settings</b>.</li>
        <li>Paste the license key from your Gumroad receipt email.</li>
        <li>Click <b>Verify license</b> - Pro unlocks instantly.</li>
      </ol>
    </div>
  </main>
</Base>
