---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const readMins = (body: string) => Math.max(1, Math.round(body.split(/\s+/).filter(Boolean).length / 200));
---
<Base title="Blog & Tips - AI Karma Tracker" description="Tips and guides for getting the most out of your AI usage limits.">
  <header class="blog-head wrap">
    <p class="eyebrow">BLOG</p>
    <h1>Make your AI limits go further</h1>
    <p class="muted lead">Deep dives on limits, resets and getting more out of every AI tool.</p>
  </header>

  <section class="wrap grid">
    {posts.map((post) => (
      <PostCard
        href={`/blog/${post.id}`}
        title={post.data.title}
        description={post.data.description}
        tag={post.data.tag}
        date={post.data.date}
        readMins={readMins(post.body)}
        image={post.data.image}
      />
    ))}
  </section>
</Base>

<style>
  .blog-head { padding: 64px 24px 0; text-align: center; }
  .eyebrow { font-size: 13px; font-weight: 700; letter-spacing: .08em; color: var(--brand-ink); }
  .blog-head h1 { font-size: 42px; margin-top: 10px; }
  .lead { font-size: 18px; max-width: 560px; margin: 16px auto 0; }
  .grid {
    padding: 44px 24px 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;
  }
</style>
