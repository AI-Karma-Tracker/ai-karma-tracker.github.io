---
import Base from '../layouts/Base.astro';
const EMAIL = 'anliberant@gmail.com';
const COMPANY = 'Anton Liberant';
const COUNTRY = 'Israel';
---
<Base title="Contact - AI Karma Tracker" description="Get in touch with AI Karma Tracker support.">
  <main class="wrap legal" style="max-width:760px; padding:56px 24px 20px">
    <h1 style="font-size:38px">Contact</h1>
    <p>We’re happy to help with billing, license activation, or bug reports.</p>

    <div class="panel" style="margin-top:20px">
      <h2 style="margin:0;font-size:18px">Support</h2>
      <p style="margin-top:8px">Email <a href={`mailto:${EMAIL}`} style="color:var(--brand);font-weight:600">{EMAIL}</a> - we usually reply within 1-2 business days.</p>
      <p class="muted" style="margin-top:10px;font-size:14px">For faster help with a subscription, include your license key or Gumroad receipt.</p>
    </div>

    <p class="muted" style="margin-top:20px;font-size:14px">{COMPANY} · {COUNTRY}</p>
  </main>
  <style>
    .legal p { margin:10px 0; color:#334155; line-height:1.75; }
  </style>
</Base>
