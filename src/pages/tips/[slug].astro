---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import PostCta from '../../components/PostCta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('tips');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, tag, date, image, readMins } = post.data;
const mins = readMins ?? Math.max(1, Math.round(post.body.split(/\s+/).filter(Boolean).length / 200));
const fmt = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<Base title={`${title} - AI Karma Tracker`} description={description}>
  <article class="post wrap">
    <a href="/tips" class="muted back">← All tips</a>

    <div class="meta">
      <span class="tag">{tag}</span>
      <span class="muted">{fmt} · {mins} min read</span>
    </div>
    <h1>{title}</h1>
    <p class="muted subtitle">{description}</p>

    {image && (
      <figure class="hero">
        <Image src={image} alt={title} widths={[600, 1000]} sizes="(max-width: 820px) 100vw, 760px" />
      </figure>
    )}

    <div class="prose"><Content /></div>

    <PostCta />
  </article>
</Base>

<style>
  .post { max-width: 780px; padding: 56px 24px 24px; }
  .back { font-size: 14px; }
  .meta { display: flex; gap: 8px; align-items: center; font-size: 13px; margin-top: 18px; }
  .tag {
    font-weight: 700; color: var(--brand-ink);
    background: #eef2ff; border: 1px solid #e0e7ff;
    padding: 2px 8px; border-radius: 999px;
  }
  .post h1 { font-size: 38px; margin-top: 14px; line-height: 1.15; }
  .subtitle { font-size: 18px; margin-top: 12px; }
  .hero {
    margin: 28px 0 0; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border); aspect-ratio: 16 / 9; background: var(--bg-soft);
  }
  .hero :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>

<style is:global>
  .prose { margin-top: 28px; font-size: 17px; line-height: 1.75; }
  .prose h2 { font-size: 24px; margin: 32px 0 10px; }
  .prose h3 { font-size: 19px; margin: 24px 0 8px; }
  .prose p { margin: 14px 0; }
  .prose ul, .prose ol { margin: 14px 0; padding-left: 24px; }
  .prose li { margin: 6px 0; }
  .prose strong { font-weight: 700; }
  .prose a { color: var(--brand); text-decoration: underline; }
  .prose code { background: var(--bg-soft); padding: 2px 6px; border-radius: 6px; font-size: 15px; }
</style>
