---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  title: string;
  description: string;
  tag: string;
  date: Date;
  readMins: number;
  image?: ImageMetadata;
}
const { href, title, description, tag, date, readMins, image } = Astro.props;
const fmt = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<a class="post-card reveal" href={href}>
  <div class="cover">
    {image
      ? <Image src={image} alt={title} widths={[400, 760]} sizes="(max-width: 640px) 100vw, 380px" />
      : <span class="cover-fallback">{tag}</span>}
  </div>
  <div class="body">
    <div class="meta">
      <span class="tag">{tag}</span>
      <span class="muted">{fmt} · {readMins} min</span>
    </div>
    <h2>{title}</h2>
    <p class="muted excerpt">{description}</p>
    <span class="read">Read →</span>
  </div>
</a>
<style>
  .post-card {
    display: flex; flex-direction: column; overflow: hidden;
    text-decoration: none; color: inherit;
    background: var(--panel); border: 1px solid var(--border);
    border-radius: var(--radius); box-shadow: var(--shadow);
    transition: transform .15s ease, box-shadow .2s ease;
  }
  .post-card:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(16, 24, 40, .12); }
  .cover { aspect-ratio: 16 / 9; overflow: hidden; background: var(--bg-soft); }
  .cover :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cover-fallback {
    display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;
    background: linear-gradient(135deg, #eef2ff, #f5f0ff);
    color: var(--brand-ink); font-weight: 800; font-size: 22px; letter-spacing: .02em;
  }
  .body { padding: 18px 20px 20px; }
  .meta { display: flex; gap: 8px; align-items: center; font-size: 12px; }
  .tag {
    font-weight: 700; color: var(--brand-ink);
    background: #eef2ff; border: 1px solid #e0e7ff;
    padding: 2px 8px; border-radius: 999px;
  }
  .post-card h2 { font-size: 19px; line-height: 1.25; margin: 12px 0 0; }
  .excerpt {
    margin-top: 8px; font-size: 14.5px; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .read { display: inline-block; margin-top: 14px; color: var(--brand); font-weight: 600; font-size: 14px; }
</style>
